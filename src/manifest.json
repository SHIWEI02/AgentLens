{
  "package": "com.swei.watch.agentlens",
  "name": "AgentLens",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1000,
  "icon": "/common/logo.png",
  "deviceTypeList": [
    "watch"
  ],
  "features": [
    {
      "name": "system.router"
    },
    {
      "name": "system.fetch"
    },
    {
      "name": "system.vibrator"
    },
    {
      "name": "system.storage"
    },
    {
      "name": "system.app"
    },
    {
      "name": "system.device"
    },
    {
      "name": "system.configuration"
    },
    {
      "name": "system.network"
    }
  ],
  "config": {
    "logLevel": "log",
    "designWidth": 480
