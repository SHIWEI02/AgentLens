# ntfy.sh 配置
# 在 https://ntfy.sh 创建一个 topic（免费，无需注册）
NTFY_TOPIC=your-secret-topic-name
NTFY_SERVER=https://ntfy.sh

# 超时配置（秒）
# 手表端审批超时时间，超时后自动拒绝
APPROVE_TIMEOUT=60

# 危险命令正则（逗号分隔）
# 匹配到这些命令时会推送到手表审批
DANGEROUS_COMMANDS=rm -rf,sudo,git push --force,docker rm,docker prune,terraform destroy,chmod 777

# 保护路径（逗号分隔）
# 防止 agent 修改这些路径下的文件
PROTECTED_PATHS=.claude/hooks/,watch_approve.py,watch_done.py,watch.env

# Claude Code Hook 配置路径
